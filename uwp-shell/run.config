# uwp-shell/run.config
# Set mode=test to run shim tests inside the UWP sandbox.
# Set mode=game to run a game .exe (fill in exe/cwd/args below).

mode=test

# --- Game mode settings (used when mode=game) ---
# exe=C:\Game\Binaries\Win64\HalfSword.exe
# cwd=C:\Game\
# args=-dx11 -windowed -resx=1920 -resy=1080
# dll_search_path=C:\Game\Binaries\Win64;C:\Game\Engine\Binaries\Win64
