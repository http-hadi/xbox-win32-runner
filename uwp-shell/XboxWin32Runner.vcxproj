      <AdditionalIncludeDirectories>$(ProjectDir);$(ProjectDir)..\pe-loader;$(ProjectDir)..\shims;$(ProjectDir)..\shims\kernel32;$(ProjectDir)..\shims\user32;$(ProjectDir)..\shims\gdi32;$(ProjectDir)..\shims\advapi32;$(ProjectDir)..\shims\shell32;$(ProjectDir)..\shims\shlwapi;$(ProjectDir)..\shims\ole32;$(ProjectDir)..\shims\winmm;$(ProjectDir)..\shims\version;$(ProjectDir)..\shims\pass-through;$(ProjectDir)..\shims\stubs;$(ProjectDir)..\shims\legacy;$(ProjectDir)..\d3d11-bridge;$(ProjectDir)..\bridges;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
